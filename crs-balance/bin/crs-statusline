#!/usr/bin/env bash
set -u

input="$(cat)"
config_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
env_file="${CRS_ENV_FILE:-$config_dir/crs-balance.env}"

if [[ -f "$env_file" ]]; then
  # shellcheck disable=SC1090
  source "$env_file"
fi

run_upstream() {
  case "$input" in
    \{*) ;;
    *) return 0 ;;
  esac

  # 首选:install.sh 接管时记录的上游 statusLine 命令。任何其他 statusline 插件都能这样接进来。
  local upstream_file="$config_dir/crs-statusline.upstream"
  if [[ -s "$upstream_file" ]]; then
    local upstream_cmd
    upstream_cmd="$(tr -d '\r' < "$upstream_file" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    if [[ -n "$upstream_cmd" ]]; then
      printf '%s' "$input" | bash -c "$upstream_cmd" 2>/dev/null || true
      return 0
    fi
  fi

  # 兼容 fallback:老用户没有 upstream 文件,但装了 claude-hud 的情况。
  local hud_dir
  hud_dir="$(
    ls -d "$config_dir"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null |
      awk -F/ '{ print $(NF-1) "\t" $(0) }' |
      sort -t. -k1,1n -k2,2n -k3,3n -k4,4n |
      tail -1 |
      cut -f2-
  )"
  if [[ -n "${hud_dir:-}" && -f "${hud_dir}dist/index.js" ]] && command -v node >/dev/null 2>&1; then
    printf '%s' "$input" | node "${hud_dir}dist/index.js" 2>/dev/null || true
  fi
}

run_crs() {
  local crs_bin="${script_dir}/crs-balance"
  if [[ -x "$crs_bin" ]]; then
    "$crs_bin" --statusline 2>/dev/null || true
  elif command -v crs-balance >/dev/null 2>&1; then
    crs-balance --statusline 2>/dev/null || true
  fi
}

upstream="$(run_upstream)"
crs="$(run_crs)"

if [[ -n "$upstream" && -n "$crs" ]]; then
  printf '%s\n%s\n' "$upstream" "$crs"
elif [[ -n "$crs" ]]; then
  printf '%s\n' "$crs"
else
  printf '%s\n' "$upstream"
fi
