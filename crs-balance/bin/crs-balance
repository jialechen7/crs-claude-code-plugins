#!/usr/bin/env node

"use strict";

const DEFAULT_BASE_URL = "https://250924.xyz";
const DEFAULT_INTERVAL_SECONDS = 300;
const DEFAULT_TIMEOUT_MS = 15000;
const DEFAULT_CACHE_SECONDS = 300;

function stripInlineComment(value) {
  let quote = null;
  for (let i = 0; i < value.length; i += 1) {
    const ch = value[i];
    if ((ch === "'" || ch === '"') && value[i - 1] !== "\\") {
      quote = quote === ch ? null : quote || ch;
    }
    if (ch === "#" && !quote) {
      return value.slice(0, i).trim();
    }
  }
  return value.trim();
}

function parseEnvValue(value) {
  const trimmed = stripInlineComment(value);
  if (trimmed.length >= 2) {
    const first = trimmed[0];
    const last = trimmed[trimmed.length - 1];
    if ((first === "'" && last === "'") || (first === '"' && last === '"')) {
      const inner = trimmed.slice(1, -1);
      return first === '"'
        ? inner.replace(/\\n/g, "\n").replace(/\\r/g, "\r").replace(/\\t/g, "\t").replace(/\\"/g, '"').replace(/\\\\/g, "\\")
        : inner;
    }
  }
  return trimmed;
}

function loadEnvFile() {
  const fs = require("fs");
  const path = require("path");
  const configDir = process.env.CLAUDE_CONFIG_DIR || path.join(process.env.HOME || process.cwd(), ".claude");
  const envFile = process.env.CRS_ENV_FILE || path.join(configDir, "crs-balance.env");
  let raw;
  try {
    raw = fs.readFileSync(envFile, "utf8");
  } catch (_) {
    return;
  }

  for (const line of raw.split(/\r?\n/)) {
    const match = line.match(/^\s*(?:export\s+)?([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.*)$/);
    if (!match) {
      continue;
    }
    const [, key, value] = match;
    if (process.env[key] === undefined) {
      process.env[key] = parseEnvValue(value);
    }
  }
}

loadEnvFile();

function loadClaudeSettingsEnv() {
  const fs = require("fs");
  const path = require("path");
  const configDir = process.env.CLAUDE_CONFIG_DIR || path.join(process.env.HOME || process.cwd(), ".claude");
  const settingsFile = path.join(configDir, "settings.json");
  let data;
  try {
    data = JSON.parse(fs.readFileSync(settingsFile, "utf8"));
  } catch (_) {
    return;
  }
  const env = data && typeof data.env === "object" ? data.env : null;
  if (!env) {
    return;
  }
  for (const key of ["ANTHROPIC_AUTH_TOKEN", "ANTHROPIC_BASE_URL"]) {
    if (process.env[key] === undefined && typeof env[key] === "string") {
      process.env[key] = env[key];
    }
  }
}

loadClaudeSettingsEnv();

function readOption(key, envName, fallback = undefined) {
  return (
    process.env[envName] ||
    process.env[`CLAUDE_PLUGIN_OPTION_${key}`] ||
    process.env[`CLAUDE_PLUGIN_OPTION_${key.toUpperCase()}`] ||
    fallback
  );
}

function splitList(value) {
  if (!value) {
    return [];
  }
  return String(value)
    .split(",")
    .map((item) => item.trim())
    .filter(Boolean);
}

function parseArgs(argv) {
  const opts = {
    watch: false,
    json: false,
    statusline: false,
    all: false,
    baseUrl: readOption("base_url", "CRS_BASE_URL", DEFAULT_BASE_URL),
    username: readOption("admin_user", "CRS_ADMIN_USER"),
    password: readOption("admin_pass", "CRS_ADMIN_PASS"),
    interval: Number(readOption("interval", "CRS_INTERVAL", DEFAULT_INTERVAL_SECONDS)),
    timeoutMs: Number(readOption("timeout_ms", "CRS_TIMEOUT_MS", DEFAULT_TIMEOUT_MS)),
    cacheSeconds: Number(readOption("cache_seconds", "CRS_CACHE_SECONDS", DEFAULT_CACHE_SECONDS)),
    accountId: readOption("account_id", "CRS_ACCOUNT_ID"),
    accountName: readOption("account_name", "CRS_ACCOUNT_NAME"),
    accountNames: readOption("account_names", "CRS_ACCOUNT_NAMES"),
    accountFilter: readOption("account_filter", "CRS_ACCOUNT_FILTER"),
    apiKeyId: readOption("api_key_id", "CRS_API_KEY_ID"),
    apiKeyName: readOption("api_key_name", "CRS_API_KEY_NAME"),
    apiKey: readOption("api_key", "CRS_API_KEY") || process.env.ANTHROPIC_AUTH_TOKEN,
    keyShare: readOption("key_share", "CRS_KEY_SHARE", "1"),
  };

  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === "--watch") {
      opts.watch = true;
    } else if (arg === "--json") {
      opts.json = true;
    } else if (arg === "--statusline") {
      opts.statusline = true;
    } else if (arg === "--all") {
      opts.all = true;
    } else if (arg === "--base-url") {
      opts.baseUrl = argv[++i];
    } else if (arg === "--user" || arg === "--username") {
      opts.username = argv[++i];
    } else if (arg === "--password") {
      opts.password = argv[++i];
    } else if (arg === "--account-id") {
      opts.accountId = argv[++i];
    } else if (arg === "--account-name") {
      opts.accountName = argv[++i];
    } else if (arg === "--account-names") {
      opts.accountNames = argv[++i];
    } else if (arg === "--account-filter") {
      opts.accountFilter = argv[++i];
    } else if (arg === "--api-key-id") {
      opts.apiKeyId = argv[++i];
    } else if (arg === "--api-key-name") {
      opts.apiKeyName = argv[++i];
    } else if (arg === "--api-key") {
      opts.apiKey = argv[++i];
    } else if (arg === "--no-key-share") {
      opts.keyShare = "0";
    } else if (arg === "--cache-seconds") {
      opts.cacheSeconds = Number(argv[++i]);
    } else if (arg === "--interval") {
      opts.interval = Number(argv[++i]);
    } else if (arg === "--timeout") {
      opts.timeoutMs = Number(argv[++i]) * 1000;
    } else if (arg === "--help" || arg === "-h") {
      printHelp();
      process.exit(0);
    } else {
      throw new Error(`未知参数: ${arg}`);
    }
  }

  opts.baseUrl = String(opts.baseUrl || DEFAULT_BASE_URL).replace(/\/+$/, "");
  if (!opts.username || !opts.password) {
    if (opts.statusline) {
      opts.missingCredentials = true;
    } else {
      throw new Error("缺少 CRS admin 凭据：请配置插件 userConfig，或设置 CRS_ADMIN_USER 和 CRS_ADMIN_PASS。");
    }
  }
  if (!Number.isFinite(opts.interval) || opts.interval <= 0) {
    throw new Error("--interval 必须是正数秒。");
  }
  if (!Number.isFinite(opts.timeoutMs) || opts.timeoutMs <= 0) {
    throw new Error("--timeout 必须是正数秒。");
  }
  if (!Number.isFinite(opts.cacheSeconds) || opts.cacheSeconds < 0) {
    throw new Error("--cache-seconds 必须是非负秒数。");
  }
  opts.accountNamesList = [
    ...splitList(opts.accountName),
    ...splitList(opts.accountNames),
  ].map((name) => name.toLowerCase());
  opts.keyShareEnabled = opts.keyShare !== "0" && opts.keyShare !== "false";
  return opts;
}

function printHelp() {
  console.log(`Usage: crs-balance [--json] [--watch] [--statusline] [--interval seconds] [--base-url url]

查看 CRS 上游 Claude 账号 5h / 7d / 7d-Opus 使用率和剩余额度。

筛选：
  --account-id <id>
  --account-name <name>
  --account-names <name1,name2>
  --account-filter <text>
  --api-key-id <id>
  --api-key-name <name>
  --api-key <key>
  --no-key-share
  --all

配置来源：
  插件 userConfig: base_url, admin_user, admin_pass
  环境变量: CRS_BASE_URL, CRS_ADMIN_USER, CRS_ADMIN_PASS, CRS_INTERVAL
  账号筛选环境变量: CRS_ACCOUNT_ID, CRS_ACCOUNT_NAME, CRS_ACCOUNT_NAMES, CRS_ACCOUNT_FILTER
  当前 key 环境变量: CRS_API_KEY_ID, CRS_API_KEY_NAME, CRS_API_KEY, ANTHROPIC_AUTH_TOKEN
  statusLine 进度条宽度: CRS_BAR_CELLS（5-40，默认 20）或 COLUMNS（auto: (cols-80)/2）
`);
}

async function http(opts, method, path, token, body) {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), opts.timeoutMs);
  try {
    const headers = {
      "accept": "application/json",
      "content-type": "application/json",
      "user-agent": "crs-balance-plugin/0.1.0",
    };
    if (token) {
      headers.authorization = `Bearer ${token}`;
    }

    const resp = await fetch(`${opts.baseUrl}${path}`, {
      method,
      headers,
      body: body === undefined ? undefined : JSON.stringify(body),
      signal: controller.signal,
    });
    const text = await resp.text();
    const payload = text ? JSON.parse(text) : null;
    if (!resp.ok) {
      const detail = payload && typeof payload === "object" ? JSON.stringify(payload) : text;
      const err = new Error(`${method} ${path} failed: HTTP ${resp.status} ${detail || ""}`.trim());
      err.status = resp.status;
      throw err;
    }
    return payload;
  } finally {
    clearTimeout(timer);
  }
}

async function login(opts) {
  const payload = await http(opts, "POST", "/web/auth/login", null, {
    username: opts.username,
    password: opts.password,
  });
  if (!payload || payload.success !== true || !payload.token) {
    throw new Error(`登录失败: ${JSON.stringify(payload)}`);
  }
  return payload.token;
}

function publicBaseUrl(opts) {
  return String(process.env.ANTHROPIC_BASE_URL || opts.baseUrl || DEFAULT_BASE_URL)
    .replace(/\/api\/?$/, "")
    .replace(/\/+$/, "");
}

async function resolveCurrentApiKeyId(opts, token) {
  if (opts.apiKeyId) {
    return String(opts.apiKeyId);
  }

  if (opts.apiKey) {
    try {
      const baseUrl = publicBaseUrl(opts);
      const resp = await fetch(`${baseUrl}/apiStats/api/get-key-id`, {
        method: "POST",
        headers: {
          "accept": "application/json",
          "content-type": "application/json",
          "user-agent": "crs-balance-plugin/0.1.0",
        },
        body: JSON.stringify({ apiKey: opts.apiKey }),
      });
      const payload = await resp.json().catch(() => null);
      if (resp.ok && payload?.success === true && payload?.data?.id) {
        return String(payload.data.id);
      }
    } catch (_) {
      // statusLine 场景降级为不展示 key 占比。
    }
  }

  if (opts.apiKeyName && token) {
    try {
      const payload = await http(
        opts,
        "GET",
        `/admin/api-keys?page=1&pageSize=100&searchMode=apiKey&search=${encodeURIComponent(opts.apiKeyName)}`,
        token
      );
      const items = payload?.data?.items || [];
      const exact = items.find((item) => item?.name === opts.apiKeyName);
      if (exact?.id) {
        return String(exact.id);
      }
    } catch (_) {
      // statusLine 场景降级为不展示 key 占比。
    }
  }

  return null;
}

async function fetchSnapshot(opts, token) {
  const [accountsResp, usageResp] = await Promise.all([
    http(opts, "GET", "/admin/claude-accounts", token),
    http(opts, "GET", "/admin/claude-accounts/usage", token),
  ]);

  const accounts = Array.isArray(accountsResp)
    ? accountsResp
    : Array.isArray(accountsResp?.data)
      ? accountsResp.data
      : [];
  const usage = usageResp && typeof usageResp === "object"
    ? usageResp.data && typeof usageResp.data === "object"
      ? usageResp.data
      : usageResp
    : {};

  const snapshot = normalizeSnapshot(accounts, usage);
  if (opts.keyShareEnabled) {
    await enrichKeyShare(snapshot, opts, token);
  }
  return snapshot;
}

function normalizeSnapshot(accounts, usage) {
  const byId = new Map();
  for (const account of accounts) {
    if (account && typeof account === "object" && account.id) {
      byId.set(String(account.id), account);
    }
  }

  const rows = [];
  const seen = new Set();
  for (const [id, snap] of Object.entries(usage || {})) {
    seen.add(id);
    rows.push(buildRow(id, byId.get(id) || {}, snap || {}));
  }

  for (const [id, account] of byId.entries()) {
    if (!seen.has(id)) {
      rows.push(buildRow(id, account, {}));
    }
  }

  rows.sort((a, b) => a.account.localeCompare(b.account));
  return {
    generatedAt: new Date().toISOString(),
    accounts: rows,
  };
}

function applyAccountFilter(snapshot, opts) {
  if (opts.all) {
    return snapshot;
  }

  const filter = opts.accountFilter ? String(opts.accountFilter).toLowerCase() : null;
  const accountId = opts.accountId ? String(opts.accountId) : null;
  const accountNames = Array.isArray(opts.accountNamesList) ? opts.accountNamesList : [];
  const accountNameSet = new Set(accountNames);

  if (!filter && !accountId && accountNameSet.size === 0) {
    return snapshot;
  }

  return {
    ...snapshot,
    accounts: snapshot.accounts.filter((row) => {
      if (accountId) {
        return row.id === accountId;
      }
      if (accountNameSet.size > 0) {
        return accountNameSet.has(row.account.toLowerCase());
      }
      return row.id.toLowerCase().includes(filter) || row.account.toLowerCase().includes(filter);
    }),
  };
}

function buildRow(id, account, snap) {
  const five = snap.fiveHour || {};
  const seven = snap.sevenDay || {};
  const opus = snap.sevenDayOpus || {};
  return {
    id,
    account: String(account.name || id || "?"),
    windows: {
      fiveHour: windowData(five),
      sevenDay: windowData(seven),
      sevenDayOpus: windowData(opus),
    },
    status: statusTags(account),
  };
}

function windowData(value) {
  const used = numberOrNull(value.utilization);
  return {
    usedPct: used,
    remainingPct: used === null ? null : 100 - used,
    resetsAt: value.resetsAt || null,
  };
}

function rollingWindow(resetsAt, spanHours) {
  if (!resetsAt) {
    return null;
  }
  const reset = new Date(resetsAt);
  if (Number.isNaN(reset.getTime())) {
    return null;
  }
  const start = new Date(reset.getTime() - spanHours * 60 * 60 * 1000);
  const now = new Date();
  const end = now < reset ? now : reset;
  return {
    startDate: start.toISOString(),
    endDate: end.toISOString(),
  };
}

function fiveHourWindow(row) {
  return rollingWindow(row?.windows?.fiveHour?.resetsAt, 5);
}

function sevenDayWindow(row) {
  return rollingWindow(row?.windows?.sevenDay?.resetsAt, 24 * 7);
}

async function fetchAccountUsageSummary(opts, token, accountId, window, apiKeyId) {
  const params = new URLSearchParams({
    platform: "claude",
    startDate: window.startDate,
    endDate: window.endDate,
    page: "1",
    pageSize: "1",
  });
  if (apiKeyId) {
    params.set("apiKeyId", apiKeyId);
  }
  const payload = await http(
    opts,
    "GET",
    `/admin/accounts/${encodeURIComponent(accountId)}/usage-records?${params.toString()}`,
    token
  );
  return payload?.data?.summary || null;
}

async function fetchRequestDetailUsageSummary(opts, token, accountId, window, apiKeyId) {
  const params = new URLSearchParams({
    accountId,
    startDate: window.startDate,
    endDate: window.endDate,
    page: "1",
    pageSize: "1",
  });
  if (apiKeyId) {
    params.set("apiKeyId", apiKeyId);
  }
  const payload = await http(opts, "GET", `/admin/request-details?${params.toString()}`, token);
  const data = payload?.data;
  if (!data || data.captureEnabled === false || !data.summary) {
    return null;
  }
  return data.summary;
}

async function fetchKeyShareUsageSummary(opts, token, accountId, window, apiKeyId) {
  const spanHours = (new Date(window.endDate).getTime() - new Date(window.startDate).getTime()) / 3600000;
  if (spanHours <= 6) {
    const requestDetailSummary = await fetchRequestDetailUsageSummary(opts, token, accountId, window, apiKeyId);
    if (requestDetailSummary) {
      return requestDetailSummary;
    }
  }
  return fetchAccountUsageSummary(opts, token, accountId, window, apiKeyId);
}

function summaryTotalCost(summary) {
  if (!summary) {
    return 0;
  }
  const cost = Number(summary.totalCost);
  return Number.isFinite(cost) && cost > 0 ? cost : 0;
}

async function computeKeyShare(opts, token, accountId, window, apiKeyId) {
  if (!window) {
    return null;
  }
  try {
    const [totalSummary, keySummary] = await Promise.all([
      fetchKeyShareUsageSummary(opts, token, accountId, window, null),
      fetchKeyShareUsageSummary(opts, token, accountId, window, apiKeyId),
    ]);
    const totalCost = summaryTotalCost(totalSummary);
    const keyCost = summaryTotalCost(keySummary);
    if (totalCost <= 0) {
      return { keyCost, totalCost, pct: null };
    }
    return { keyCost, totalCost, pct: (keyCost / totalCost) * 100 };
  } catch (_) {
    return null;
  }
}

async function enrichKeyShare(snapshot, opts, token) {
  snapshot.keyShareAttempted = true;
  const apiKeyId = await resolveCurrentApiKeyId(opts, token);
  if (!apiKeyId) {
    return;
  }

  const filtered = applyAccountFilter(snapshot, opts).accounts;
  await Promise.all(filtered.map(async (row) => {
    const [fiveHourShare, sevenDayShare] = await Promise.all([
      computeKeyShare(opts, token, row.id, fiveHourWindow(row), apiKeyId),
      computeKeyShare(opts, token, row.id, sevenDayWindow(row), apiKeyId),
    ]);
    if (!fiveHourShare && !sevenDayShare) {
      return;
    }
    row.keyShare = {
      apiKeyId,
      fiveHour: fiveHourShare,
      sevenDay: sevenDayShare,
    };
  }));
}

function numberOrNull(value) {
  if (value === null || value === undefined || value === "") {
    return null;
  }
  const n = Number(value);
  return Number.isFinite(n) ? n : null;
}

function statusTags(account) {
  const tags = [];
  if (account.fiveHourAutoStopped === true || account.fiveHourAutoStopped === "true") {
    tags.push("5h-STOPPED");
  }
  if (account.rateLimitStatus === "limited") {
    tags.push("LIMITED");
  }
  if (account.schedulable === false) {
    tags.push("unsched");
  }
  return tags.length ? tags : ["ok"];
}

function pct(value) {
  if (value === null || value === undefined) {
    return "   -  ";
  }
  return `${value.toFixed(1).padStart(5)}%`;
}

function resetTime(iso) {
  if (!iso) {
    return "-";
  }
  const t = new Date(iso);
  if (Number.isNaN(t.getTime())) {
    return String(iso);
  }
  const deltaHours = (t.getTime() - Date.now()) / 3600000;
  const month = String(t.getMonth() + 1).padStart(2, "0");
  const day = String(t.getDate()).padStart(2, "0");
  const hour = String(t.getHours()).padStart(2, "0");
  const minute = String(t.getMinutes()).padStart(2, "0");
  const formatted = `${month}-${day} ${hour}:${minute}`;
  return deltaHours >= 0 ? `${formatted} (+${deltaHours.toFixed(1)}h)` : formatted;
}

function render(snapshot) {
  const header =
    `${"Account".padEnd(22)} ` +
    `${"5h used".padStart(8)} ${"5h left".padStart(8)} ${"5h reset".padEnd(22)} ` +
    `${"7d used".padStart(8)} ${"7d left".padStart(8)} ${"7d reset".padEnd(22)} ` +
    `${"Opus used".padStart(9)} ${"Opus left".padStart(9)} ${"Opus reset".padEnd(22)} Status`;
  const lines = [header, "-".repeat(header.length)];

  for (const row of snapshot.accounts) {
    const five = row.windows.fiveHour;
    const seven = row.windows.sevenDay;
    const opus = row.windows.sevenDayOpus;
    lines.push(
      `${row.account.slice(0, 22).padEnd(22)} ` +
      `${pct(five.usedPct).padStart(8)} ${pct(five.remainingPct).padStart(8)} ${resetTime(five.resetsAt).padEnd(22)} ` +
      `${pct(seven.usedPct).padStart(8)} ${pct(seven.remainingPct).padStart(8)} ${resetTime(seven.resetsAt).padEnd(22)} ` +
      `${pct(opus.usedPct).padStart(9)} ${pct(opus.remainingPct).padStart(9)} ${resetTime(opus.resetsAt).padEnd(22)} ` +
      row.status.join(",")
    );
  }

  if (snapshot.accounts.length === 0) {
    lines.push("(no accounts returned)");
  }
  return lines.join("\n");
}

const CACHE_SCHEMA = 2;

function cachePath() {
  const home = process.env.HOME || process.cwd();
  return process.env.CRS_CACHE_FILE || `${home}/.claude/crs-balance-status-cache-v${CACHE_SCHEMA}.json`;
}

function apiKeyFingerprint(opts) {
  const apiKey = opts.apiKey || "";
  if (!apiKey) {
    return "anon";
  }
  return require("crypto").createHash("sha256").update(apiKey).digest("hex").slice(0, 12);
}

function readCachedSnapshot(opts) {
  try {
    const fs = require("fs");
    const raw = fs.readFileSync(cachePath(), "utf8");
    const cached = JSON.parse(raw);
    if (!cached || !cached.generatedAt || !cached.snapshot) {
      return null;
    }
    if (cached.schema !== CACHE_SCHEMA) {
      return null;
    }
    if (cached.apiKeyFingerprint !== apiKeyFingerprint(opts)) {
      return null;
    }
    if (opts.keyShareEnabled && cached.snapshot.keyShareAttempted !== true) {
      return null;
    }
    const ageSeconds = (Date.now() - new Date(cached.generatedAt).getTime()) / 1000;
    return ageSeconds <= opts.cacheSeconds ? cached.snapshot : null;
  } catch (_) {
    return null;
  }
}

function writeCachedSnapshot(opts, snapshot) {
  try {
    const fs = require("fs");
    const path = require("path");
    const file = cachePath();
    fs.mkdirSync(path.dirname(file), { recursive: true });
    fs.writeFileSync(
      file,
      JSON.stringify({
        schema: CACHE_SCHEMA,
        generatedAt: new Date().toISOString(),
        apiKeyFingerprint: apiKeyFingerprint(opts),
        snapshot,
      }),
      "utf8"
    );
  } catch (_) {
    // statusLine 场景不能因为缓存写入失败影响 Claude Code 界面。
  }
}

const ANSI = {
  reset: "\x1b[0m",
  dim: "\x1b[2m",
  cyan: "\x1b[36m",
  green: "\x1b[32m",
  yellow: "\x1b[33m",
  red: "\x1b[31m",
  teal: "\x1b[38;5;80m",
};

function color(text, code) {
  if (process.env.CRS_NO_COLOR) {
    return text;
  }
  return `${code}${text}${ANSI.reset}`;
}

function compactPct(value) {
  if (value === null || value === undefined) {
    return "  -";
  }
  return `${Math.max(0, value).toFixed(0)}%`.padStart(4);
}

function usageColor(value) {
  if (value === null || value === undefined) {
    return ANSI.dim;
  }
  if (value >= 80) {
    return ANSI.red;
  }
  if (value >= 50) {
    return ANSI.yellow;
  }
  return ANSI.teal;
}

const BAR_CELLS_MIN = 5;
const BAR_CELLS_MAX = 40;
const BAR_CELLS_DEFAULT = 20;
const STATUSLINE_NON_BAR_WIDTH = 80;

function resolveBarCells() {
  const explicit = Number(process.env.CRS_BAR_CELLS);
  if (Number.isFinite(explicit) && explicit >= BAR_CELLS_MIN) {
    return Math.min(BAR_CELLS_MAX, Math.floor(explicit));
  }
  const cols = (() => {
    if (process.stdout && Number.isFinite(process.stdout.columns) && process.stdout.columns > 0) {
      return process.stdout.columns;
    }
    const env = Number(process.env.COLUMNS);
    return Number.isFinite(env) && env > 0 ? env : 0;
  })();
  if (!cols) {
    return BAR_CELLS_DEFAULT;
  }
  const perBar = Math.floor((cols - STATUSLINE_NON_BAR_WIDTH) / 2);
  return Math.max(BAR_CELLS_MIN, Math.min(BAR_CELLS_MAX, perBar));
}

const BAR_CELLS = resolveBarCells();
const BAR_CELL_PCT = 100 / BAR_CELLS;

function compactUsageBar(value, mineValue) {
  if (value === null || value === undefined) {
    return `${color("░".repeat(BAR_CELLS), ANSI.dim)} ${color("-", ANSI.dim)}`;
  }
  const used = Math.max(0, Math.min(100, value));
  const mine = Math.max(0, Math.min(used, mineValue == null ? 0 : mineValue));
  const usedCells = used > 0 ? Math.max(1, Math.round(used / BAR_CELL_PCT)) : 0;
  const mineCells = Math.min(usedCells, Math.round(mine / BAR_CELL_PCT));
  const othersCells = usedCells - mineCells;
  const restCells = BAR_CELLS - usedCells;
  const code = usageColor(used);
  const mineBar = color("█".repeat(mineCells), ANSI.cyan);
  const othersBar = color("▓".repeat(othersCells), code);
  const restBar = color("░".repeat(restCells), ANSI.dim);
  return `${mineBar}${othersBar}${restBar} ${color(compactPct(used), code)}`;
}

function compactReset(iso) {
  if (!iso) {
    return "";
  }
  const t = new Date(iso);
  if (Number.isNaN(t.getTime())) {
    return "";
  }
  const deltaMinutes = Math.round((t.getTime() - Date.now()) / 60000);
  if (deltaMinutes < 0) {
    return "idle";
  }
  if (deltaMinutes < 60) {
    return `${deltaMinutes}m`;
  }
  const hours = deltaMinutes / 60;
  if (hours < 24) {
    return `${hours.toFixed(1)}h`;
  }
  return `${(hours / 24).toFixed(1)}d`;
}

function isIdleWindow(window) {
  return window.usedPct !== null && window.usedPct !== undefined && window.usedPct <= 0;
}

const RESET_FIELD_WIDTH = 11;

function windowStatus(label, window, mineEffectivePct) {
  const reset = compactReset(window.resetsAt);
  let resetText = " ".repeat(RESET_FIELD_WIDTH);
  if (isIdleWindow(window) || reset === "idle") {
    resetText = color("idle".padEnd(RESET_FIELD_WIDTH), ANSI.dim);
  } else if (reset) {
    resetText = color(`reset ${reset.padStart(5)}`.padEnd(RESET_FIELD_WIDTH), ANSI.dim);
  }
  return `${color(label, ANSI.dim)} ${compactUsageBar(window.usedPct, mineEffectivePct)} ${resetText}`;
}

function mineEffectivePct(row, windowKey) {
  const share = row.keyShare && row.keyShare[windowKey];
  const window = row.windows && row.windows[windowKey];
  if (!share || share.pct == null || !window || window.usedPct == null) {
    return null;
  }
  return (window.usedPct * share.pct) / 100;
}

function keyShareStatus(row, windowKey) {
  const share = row.keyShare && row.keyShare[windowKey];
  if (!share) {
    return "";
  }
  if (share.pct === null || share.pct === undefined) {
    return ` ${color("·", ANSI.dim)} ${color("mine", ANSI.dim)} ${color("  n/a", ANSI.dim)}`;
  }
  const absolute = mineEffectivePct(row, windowKey) || 0;
  const pctText = `${absolute.toFixed(1)}%`.padStart(5);
  return ` ${color("·", ANSI.dim)} ${color("mine", ANSI.dim)} ${color(pctText, ANSI.cyan)}`;
}

function renderStatusline(snapshot, opts) {
  if (opts.missingCredentials) {
    return "CRS 未配置";
  }
  const filtered = applyAccountFilter(snapshot, opts);
  const hasAccountNames = Array.isArray(opts.accountNamesList) && opts.accountNamesList.length > 0;
  if (!opts.all && !opts.accountId && !hasAccountNames && !opts.accountFilter) {
    return "CRS 设置 CRS_ACCOUNT_NAME";
  }
  if (filtered.accounts.length === 0) {
    return "CRS 未匹配账号";
  }
  const accountWidth = Math.max(...filtered.accounts.map((row) => row.account.length));
  const rows = filtered.accounts.map((row) => {
    const status = row.status.includes("ok") ? "" : ` ${color(row.status.join(","), ANSI.red)}`;
    return `${color("crs", ANSI.cyan)} ${color("›", ANSI.dim)} ${color(row.account.padEnd(accountWidth), ANSI.dim)} ${color("·", ANSI.dim)} ${windowStatus("5h", row.windows.fiveHour, mineEffectivePct(row, "fiveHour"))}${keyShareStatus(row, "fiveHour")} ${color("·", ANSI.dim)} ${windowStatus("7d", row.windows.sevenDay, mineEffectivePct(row, "sevenDay"))}${keyShareStatus(row, "sevenDay")}${status}`;
  });
  return rows.join("\n");
}

async function once(opts, tokenHolder) {
  if (!tokenHolder.token) {
    tokenHolder.token = await login(opts);
  }
  try {
    return await fetchSnapshot(opts, tokenHolder.token);
  } catch (err) {
    if (err.status === 401) {
      tokenHolder.token = await login(opts);
      return fetchSnapshot(opts, tokenHolder.token);
    }
    throw err;
  }
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

async function main() {
  const opts = parseArgs(process.argv.slice(2));
  const tokenHolder = { token: null };

  if (opts.statusline) {
    const cached = readCachedSnapshot(opts);
    if (cached) {
      console.log(renderStatusline(cached, opts));
      return;
    }
    if (opts.missingCredentials) {
      console.log(renderStatusline({ generatedAt: new Date().toISOString(), accounts: [] }, opts));
      return;
    }
    const snapshot = await once(opts, tokenHolder);
    writeCachedSnapshot(opts, snapshot);
    console.log(renderStatusline(snapshot, opts));
    return;
  }

  while (true) {
    const snapshot = applyAccountFilter(await once(opts, tokenHolder), opts);
    if (opts.json) {
      console.log(JSON.stringify(snapshot, null, 2));
    } else {
      console.log(`[${new Date(snapshot.generatedAt).toLocaleString()}] CRS Claude 余额快照`);
      console.log(render(snapshot));
    }

    if (!opts.watch) {
      return;
    }
    await sleep(opts.interval * 1000);
  }
}

main().catch((err) => {
  const cause = err && err.cause && err.cause.message ? `: ${err.cause.message}` : "";
  const message = err && err.message ? `${err.message}${cause}` : String(err);
  console.error(`crs-balance: ${message}`);
  process.exit(1);
});
