#!/usr/bin/env node

"use strict";

const fs = require("fs");
const path = require("path");
const crypto = require("crypto");

const DEFAULT_BASE_URL = "https://250924.xyz";
const DEFAULT_CACHE_SECONDS = 30;
const CACHE_SCHEMA = 3;

// ── env helpers ─────────────────────────────────────────────────────────────

function stripInlineComment(value) {
  let inSingle = false, inDouble = false;
  for (let i = 0; i < value.length; i++) {
    const ch = value[i];
    if (ch === "'" && !inDouble) inSingle = !inSingle;
    else if (ch === '"' && !inSingle) inDouble = !inDouble;
    else if (ch === "#" && !inSingle && !inDouble) return value.slice(0, i);
  }
  return value;
}

function parseEnvValue(value) {
  let v = stripInlineComment(value).trim();
  if (
    (v.startsWith('"') && v.endsWith('"')) ||
    (v.startsWith("'") && v.endsWith("'"))
  ) {
    v = v.slice(1, -1);
  }
  return v;
}

function loadEnvFile() {
  const home = process.env.HOME || "";
  const file =
    process.env.CRS_ENV_FILE || (home ? path.join(home, ".claude", "crs-balance.env") : null);
  if (!file || !fs.existsSync(file)) return;
  const lines = fs.readFileSync(file, "utf8").split("\n");
  for (const raw of lines) {
    const line = raw.trim();
    if (!line || line.startsWith("#")) continue;
    const m = line.match(/^(?:export\s+)?([A-Z_][A-Z0-9_]*)=(.*)$/i);
    if (!m) continue;
    const [, key, val] = m;
    if (process.env[key] === undefined || process.env[key] === "") {
      process.env[key] = parseEnvValue(val);
    }
  }
}

function loadClaudeSettingsEnv() {
  const home = process.env.HOME || "";
  if (!home) return;
  const file = path.join(home, ".claude", "settings.json");
  if (!fs.existsSync(file)) return;
  try {
    const raw = fs.readFileSync(file, "utf8");
    const data = JSON.parse(raw);
    const env = data && data.env;
    if (env && typeof env === "object") {
      for (const [k, v] of Object.entries(env)) {
        if (typeof v === "string" && (process.env[k] === undefined || process.env[k] === "")) {
          process.env[k] = v;
        }
      }
    }
  } catch (_) {
    // ignore malformed
  }
}

// ── argv ────────────────────────────────────────────────────────────────────

function parseArgs(argv) {
  const opts = {
    statusline: false,
    json: false,
    watch: false,
    interval: 60,
    baseUrl: process.env.CRS_BASE_URL || DEFAULT_BASE_URL,
    token: process.env.CRS_API_KEY || process.env.ANTHROPIC_AUTH_TOKEN || null,
    cacheSeconds: Number(process.env.CRS_CACHE_SECONDS) || DEFAULT_CACHE_SECONDS,
    noColor: !!process.env.CRS_NO_COLOR
  };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    switch (a) {
      case "--statusline":
        opts.statusline = true; break;
      case "--json":
        opts.json = true; break;
      case "--watch":
        opts.watch = true; break;
      case "--interval":
        opts.interval = Number(argv[++i]) || opts.interval; break;
      case "--base-url":
        opts.baseUrl = argv[++i]; break;
      case "--token":
        opts.token = argv[++i]; break;
      case "--cache-seconds":
        opts.cacheSeconds = Number(argv[++i]) || opts.cacheSeconds; break;
      case "--no-color":
        opts.noColor = true; break;
      case "-h":
      case "--help":
        printHelp(); process.exit(0);
        break;
      default:
        if (a.startsWith("--")) {
          // 兼容旧参数:静默接受并丢弃
          if (
            a.startsWith("--user") ||
            a.startsWith("--password") ||
            a.startsWith("--account") ||
            a.startsWith("--api-key") ||
            a === "--all" ||
            a === "--no-key-share"
          ) {
            // 后面可能跟一个值,吃掉
            if (i + 1 < argv.length && !argv[i + 1].startsWith("--")) i++;
            break;
          }
          console.error(`crs-balance: unknown option ${a}`);
          process.exit(2);
        }
    }
  }
  if (opts.noColor) process.env.CRS_NO_COLOR = "1";
  return opts;
}

function printHelp() {
  console.log(`crs-balance — 查 CRS 上游 Claude 账号 5h / 7d / Opus 使用量

用法:
  crs-balance [--statusline | --json | --watch [--interval N]]

参数:
  --statusline       statusLine 单行输出
  --json             JSON 输出
  --watch            循环刷新 (interval 秒)
  --interval N       刷新间隔 (默认 60s)
  --base-url URL     覆盖默认 ${DEFAULT_BASE_URL}
  --token cr_xxx     显式提供 API key token (默认读 ANTHROPIC_AUTH_TOKEN)
  --cache-seconds N  缓存秒数 (默认 ${DEFAULT_CACHE_SECONDS})
  --no-color         禁用颜色

环境变量:
  CRS_BASE_URL, CRS_API_KEY, ANTHROPIC_AUTH_TOKEN,
  CRS_CACHE_SECONDS, CRS_NO_COLOR, CRS_BAR_CELLS

数据源: 公开只读 API ${DEFAULT_BASE_URL}/stats/key/<token>
无需 admin 凭据。`);
}

// ── HTTP ────────────────────────────────────────────────────────────────────

async function fetchKeyReport(opts) {
  if (!opts.token) {
    const err = new Error("缺少 token: 请确保 ~/.claude/settings.json 的 env.ANTHROPIC_AUTH_TOKEN 已设置,或显式传 --token cr_xxx");
    err.missingToken = true;
    throw err;
  }
  const url = `${opts.baseUrl.replace(/\/$/, "")}/stats/key/${encodeURIComponent(opts.token)}`;
  let res;
  try {
    res = await fetch(url, { method: "GET" });
  } catch (e) {
    throw new Error(`request failed: ${e.message}`);
  }
  if (res.status === 404) {
    const err = new Error("token 无法识别 (404 from stats API)");
    err.status = 404;
    throw err;
  }
  if (!res.ok) {
    const body = await res.text().catch(() => "");
    throw new Error(`HTTP ${res.status}: ${body.slice(0, 200)}`);
  }
  const data = await res.json();
  if (!Array.isArray(data) || data.length === 0) {
    throw new Error("stats API 返回空数组");
  }
  return data[0];
}

// ── snapshot building ───────────────────────────────────────────────────────

function statusTags(account) {
  const tags = [];
  if (!account) return ["?"];
  if (account.schedulable === false) tags.push("unsched");
  if (account.status && account.status !== "active") tags.push(account.status);
  if (account.sessionWindowStatus && account.sessionWindowStatus !== "allowed") {
    tags.push(account.sessionWindowStatus);
  }
  if (account.errorMessage) tags.push("ERR");
  return tags.length ? tags : ["ok"];
}

function pctOrNull(n) {
  if (n === null || n === undefined) return null;
  const v = Number(n);
  return Number.isFinite(v) ? v : null;
}

function buildSnapshot(report) {
  const acc = report.account || {};
  const used5h = pctOrNull(acc.fiveHour && acc.fiveHour.utilization);
  const used7d = pctOrNull(acc.sevenDay && acc.sevenDay.utilization);
  const usedOpus = pctOrNull(acc.sevenDay && acc.sevenDay.opusUtilization);

  const remaining = (u) => (u === null ? null : Math.max(0, 100 - u));
  const sharePct = (w) =>
    w && w.shareOfAccount != null ? pctOrNull(w.shareOfAccount * 100) : null;

  return {
    generatedAt: new Date().toISOString(),
    key: report.key,
    accounts: [
      {
        accountId: acc.id || null,
        account: acc.name || "(unknown)",
        status: statusTags(acc),
        windows: {
          fiveHour: {
            usedPct: used5h,
            remainingPct: remaining(used5h),
            resetsAt: acc.fiveHour && acc.fiveHour.resetsAt
          },
          sevenDay: {
            usedPct: used7d,
            remainingPct: remaining(used7d),
            resetsAt: acc.sevenDay && acc.sevenDay.resetsAt
          },
          sevenDayOpus: {
            usedPct: usedOpus,
            remainingPct: remaining(usedOpus),
            resetsAt: acc.sevenDay && acc.sevenDay.opusResetsAt
          }
        },
        keyShare: {
          fiveHour: { pct: sharePct(report.fiveHour) },
          sevenDay: { pct: sharePct(report.sevenDay) }
        }
      }
    ]
  };
}

// ── cache ───────────────────────────────────────────────────────────────────

function cachePath() {
  const home = process.env.HOME || process.cwd();
  return process.env.CRS_CACHE_FILE || `${home}/.claude/crs-balance-status-cache-v${CACHE_SCHEMA}.json`;
}

function tokenFingerprint(token) {
  if (!token) return "anon";
  return crypto.createHash("sha256").update(token).digest("hex").slice(0, 12);
}

function readCachedSnapshot(opts) {
  try {
    const raw = fs.readFileSync(cachePath(), "utf8");
    const cached = JSON.parse(raw);
    if (!cached || cached.schema !== CACHE_SCHEMA) return null;
    if (cached.tokenFingerprint !== tokenFingerprint(opts.token)) return null;
    const age = (Date.now() - new Date(cached.generatedAt).getTime()) / 1000;
    return age <= opts.cacheSeconds ? cached.snapshot : null;
  } catch (_) {
    return null;
  }
}

function writeCachedSnapshot(opts, snapshot) {
  try {
    const file = cachePath();
    fs.mkdirSync(path.dirname(file), { recursive: true });
    fs.writeFileSync(
      file,
      JSON.stringify({
        schema: CACHE_SCHEMA,
        generatedAt: new Date().toISOString(),
        tokenFingerprint: tokenFingerprint(opts.token),
        snapshot
      }),
      "utf8"
    );
  } catch (_) {
    // statusLine 路径不能因 fs 失败破坏 UX
  }
}

// ── rendering ───────────────────────────────────────────────────────────────

const ANSI = {
  reset: "\x1b[0m",
  dim: "\x1b[2m",
  cyan: "\x1b[36m",
  green: "\x1b[32m",
  yellow: "\x1b[33m",
  red: "\x1b[31m",
  teal: "\x1b[38;5;80m"
};

function color(text, code) {
  if (process.env.CRS_NO_COLOR) return text;
  return `${code}${text}${ANSI.reset}`;
}

function compactPct(value) {
  if (value === null || value === undefined) return "   -";
  return `${Math.max(0, value).toFixed(1)}%`.padStart(6);
}

function usageColor(value) {
  if (value === null || value === undefined) return ANSI.dim;
  if (value >= 80) return ANSI.red;
  if (value >= 50) return ANSI.yellow;
  return ANSI.teal;
}

const BAR_CELLS_MIN = 3;
const BAR_CELLS_MAX = 40;
const BAR_CELLS_DEFAULT = 8;
const STATUSLINE_NON_BAR_WIDTH = 65;

function resolveBarCells() {
  const explicit = Number(process.env.CRS_BAR_CELLS);
  if (Number.isFinite(explicit) && explicit >= BAR_CELLS_MIN) {
    return Math.min(BAR_CELLS_MAX, Math.floor(explicit));
  }
  const cols =
    process.stdout && Number.isFinite(process.stdout.columns) && process.stdout.columns > 0
      ? process.stdout.columns
      : Number(process.env.COLUMNS) || 0;
  if (!cols) return BAR_CELLS_DEFAULT;
  const perBar = Math.floor((cols - STATUSLINE_NON_BAR_WIDTH) / 2);
  return Math.max(BAR_CELLS_MIN, Math.min(BAR_CELLS_MAX, perBar));
}

const BAR_CELLS = resolveBarCells();
const BAR_CELL_PCT = 100 / BAR_CELLS;

function compactUsageBar(value, mineValue) {
  if (value === null || value === undefined) {
    return `${color("░".repeat(BAR_CELLS), ANSI.dim)} ${color("-", ANSI.dim)}`;
  }
  const used = Math.max(0, Math.min(100, value));
  const mine = Math.max(0, Math.min(used, mineValue == null ? 0 : mineValue));
  const usedCells = used > 0 ? Math.max(1, Math.round(used / BAR_CELL_PCT)) : 0;
  const mineCells = Math.min(usedCells, Math.round(mine / BAR_CELL_PCT));
  const othersCells = usedCells - mineCells;
  const restCells = BAR_CELLS - usedCells;
  const code = usageColor(used);
  const mineBar = color("█".repeat(mineCells), ANSI.cyan);
  const othersBar = color("▓".repeat(othersCells), code);
  const restBar = color("░".repeat(restCells), ANSI.dim);
  return `${mineBar}${othersBar}${restBar} ${color(compactPct(used), code)}`;
}

function compactReset(iso) {
  if (!iso) return "";
  const t = new Date(iso);
  if (Number.isNaN(t.getTime())) return "";
  const deltaMinutes = Math.round((t.getTime() - Date.now()) / 60000);
  if (deltaMinutes < 0) return "idle";
  if (deltaMinutes < 60) return `${deltaMinutes}m`;
  const hours = deltaMinutes / 60;
  if (hours < 24) return `${hours.toFixed(1)}h`;
  return `${(hours / 24).toFixed(1)}d`;
}

function isIdleWindow(window) {
  return window.usedPct !== null && window.usedPct !== undefined && window.usedPct <= 0;
}

function windowStatus(label, window, mineEffectivePct) {
  const reset = compactReset(window.resetsAt);
  let resetText = "";
  if (isIdleWindow(window) || reset === "idle") {
    resetText = ` ${color("idle", ANSI.dim)}`;
  } else if (reset) {
    resetText = ` ${color(reset, ANSI.dim)}`;
  }
  return `${color(label, ANSI.dim)} ${compactUsageBar(window.usedPct, mineEffectivePct)}${resetText}`;
}

function mineEffectivePct(row, windowKey) {
  const share = row.keyShare && row.keyShare[windowKey];
  const window = row.windows && row.windows[windowKey];
  if (!share || share.pct == null || !window || window.usedPct == null) return null;
  return (window.usedPct * share.pct) / 100;
}

function keyShareStatus(row, windowKey) {
  const share = row.keyShare && row.keyShare[windowKey];
  if (!share || share.pct == null) return "";
  const absolute = mineEffectivePct(row, windowKey) || 0;
  return ` ${color("·", ANSI.dim)} ${color("mine", ANSI.dim)} ${color(`${absolute.toFixed(1)}%`, ANSI.cyan)}`;
}

function renderStatusline(snapshot) {
  if (!snapshot.accounts.length) return "CRS 未匹配账号";
  const row = snapshot.accounts[0];
  const statusTail = row.status.includes("ok") ? "" : ` ${color(row.status.join(","), ANSI.red)}`;
  return (
    `${color("crs", ANSI.cyan)} ${color("›", ANSI.dim)} ${color(row.account, ANSI.dim)} ` +
    `${color("·", ANSI.dim)} ${windowStatus("5h", row.windows.fiveHour, mineEffectivePct(row, "fiveHour"))}${keyShareStatus(row, "fiveHour")} ` +
    `${color("·", ANSI.dim)} ${windowStatus("7d", row.windows.sevenDay, mineEffectivePct(row, "sevenDay"))}${keyShareStatus(row, "sevenDay")}${statusTail}`
  );
}

function pct(value) {
  if (value === null || value === undefined) return "   -  ";
  return `${value.toFixed(1).padStart(5)}%`;
}

function resetTime(iso) {
  if (!iso) return "-";
  const t = new Date(iso);
  if (Number.isNaN(t.getTime())) return String(iso);
  const deltaHours = (t.getTime() - Date.now()) / 3600000;
  const month = String(t.getMonth() + 1).padStart(2, "0");
  const day = String(t.getDate()).padStart(2, "0");
  const hour = String(t.getHours()).padStart(2, "0");
  const minute = String(t.getMinutes()).padStart(2, "0");
  const formatted = `${month}-${day} ${hour}:${minute}`;
  return deltaHours >= 0 ? `${formatted} (+${deltaHours.toFixed(1)}h)` : formatted;
}

function renderTable(snapshot) {
  const header =
    `${"Account".padEnd(22)} ` +
    `${"5h used".padStart(8)} ${"5h left".padStart(8)} ${"5h reset".padEnd(22)} ` +
    `${"7d used".padStart(8)} ${"7d left".padStart(8)} ${"7d reset".padEnd(22)} ` +
    `${"Opus used".padStart(9)} ${"Opus left".padStart(9)} ${"Opus reset".padEnd(22)} ` +
    `${"5h mine".padStart(8)} ${"7d mine".padStart(8)} Status`;
  const lines = [header, "-".repeat(header.length)];

  for (const row of snapshot.accounts) {
    const five = row.windows.fiveHour;
    const seven = row.windows.sevenDay;
    const opus = row.windows.sevenDayOpus;
    const mine5h = mineEffectivePct(row, "fiveHour");
    const mine7d = mineEffectivePct(row, "sevenDay");
    lines.push(
      `${row.account.slice(0, 22).padEnd(22)} ` +
      `${pct(five.usedPct).padStart(8)} ${pct(five.remainingPct).padStart(8)} ${resetTime(five.resetsAt).padEnd(22)} ` +
      `${pct(seven.usedPct).padStart(8)} ${pct(seven.remainingPct).padStart(8)} ${resetTime(seven.resetsAt).padEnd(22)} ` +
      `${pct(opus.usedPct).padStart(9)} ${pct(opus.remainingPct).padStart(9)} ${resetTime(opus.resetsAt).padEnd(22)} ` +
      `${pct(mine5h).padStart(8)} ${pct(mine7d).padStart(8)} ` +
      row.status.join(",")
    );
  }

  if (snapshot.accounts.length === 0) lines.push("(no account)");
  return lines.join("\n");
}

// ── main ────────────────────────────────────────────────────────────────────

const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

async function fetchOnce(opts) {
  const report = await fetchKeyReport(opts);
  return buildSnapshot(report);
}

async function main() {
  loadEnvFile();
  loadClaudeSettingsEnv();
  const opts = parseArgs(process.argv.slice(2));

  if (opts.statusline) {
    const cached = readCachedSnapshot(opts);
    if (cached) {
      console.log(renderStatusline(cached));
      return;
    }
    try {
      const snapshot = await fetchOnce(opts);
      writeCachedSnapshot(opts, snapshot);
      console.log(renderStatusline(snapshot));
    } catch (err) {
      if (err.missingToken) console.log("CRS 未配置 token");
      else if (err.status === 404) console.log("CRS token 无效");
      else console.log(`CRS ${err.message.slice(0, 40)}`);
    }
    return;
  }

  while (true) {
    const snapshot = await fetchOnce(opts);
    if (opts.json) {
      console.log(JSON.stringify(snapshot, null, 2));
    } else {
      console.log(`[${new Date(snapshot.generatedAt).toLocaleString()}] CRS Claude 余额快照`);
      console.log(`key: ${snapshot.key.name} (token → account ${snapshot.accounts[0].account})`);
      console.log(renderTable(snapshot));
    }
    if (!opts.watch) return;
    await sleep(opts.interval * 1000);
  }
}

main().catch((err) => {
  const cause = err && err.cause && err.cause.message ? `: ${err.cause.message}` : "";
  const message = err && err.message ? `${err.message}${cause}` : String(err);
  console.error(`crs-balance: ${message}`);
  process.exit(1);
});
